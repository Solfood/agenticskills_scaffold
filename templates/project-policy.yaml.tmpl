project_name: "<PROJECT_NAME>"
marker_prefix: "<MARKER_PREFIX>"
owner: "<OWNER>"
repo_url: "<REPO_URL>"
tech_stack: "<TECH_STACK>"
deployment_env: "<DEPLOYMENT_ENV>"

tracks:
  - ARCH   # architecture decisions
  - API    # API surface changes
  - DATA   # data model and persistence
  - SEC    # security and auth
  - OBS    # observability and metrics
  - DX     # developer experience and tooling
  - FIX    # bug fixes

# suite: list sibling repos if this project is part of a multi-repo ecosystem
# suite:
#   - name: "<SIBLING_NAME>"
#     url: "<SIBLING_REPO_URL>"
#     relationship: "<e.g. shares auth, consumes API>"

risk_tolerance: "medium"
critical_assets:
  - "user_data"
  - "auth_tokens"
compliance_requirements: []
blocking_severities:
  - "critical"
  - "high"
mandatory_gates:
  - "coherence"
  - "security"
  - "engineering_fundamentals"
  - "verification"
  - "safety"
  - "release_readiness"
